<Scene>
  <Entities>

    <!-- ============================================================= -->
    <!-- Structural visuals. BoxPrimitive3D = unit cube centered on     -->
    <!-- Position3D, scaled (no rotation). Slabs are 0.2 thick with     -->
    <!-- their TOP surface at the navmesh floor height.                 -->
    <!-- These are decoration; the player walks the navmesh, not these. -->
    <!-- ============================================================= -->

    <Entity Name="CourtyardFloor">
      <Position3D><X>6</X><Y>-0.1</Y><Z>5</Z></Position3D>
      <Component Type="BoxPrimitive3D">
        <Property Name="Scale" Value="12,0.2,10" Type="Vector3"/>
        <Property Name="Color" Value="90,84,74" Type="Color"/>
      </Component>
    </Entity>

    <Entity Name="CorridorFloor">
      <Position3D><X>3</X><Y>-0.1</Y><Z>15</Z></Position3D>
      <Component Type="BoxPrimitive3D">
        <Property Name="Scale" Value="6,0.2,10" Type="Vector3"/>
        <Property Name="Color" Value="70,66,60" Type="Color"/>
      </Component>
    </Entity>

    <Entity Name="Platform">
      <Position3D><X>8</X><Y>1.9</Y><Z>17</Z></Position3D>
      <Component Type="BoxPrimitive3D">
        <Property Name="Scale" Value="8,0.2,6" Type="Vector3"/>
        <Property Name="Color" Value="96,90,80" Type="Color"/>
      </Component>
    </Entity>

    <!-- Stairs: 8 steps rising y 0 -> 2 over z[10..14], x[6..12], meeting the platform. -->
    <Entity Name="Step0">
      <Position3D><X>9</X><Y>0.125</Y><Z>10.25</Z></Position3D>
      <Component Type="BoxPrimitive3D"><Property Name="Scale" Value="6,0.25,0.5" Type="Vector3"/><Property Name="Color" Value="82,78,70" Type="Color"/></Component>
    </Entity>
    <Entity Name="Step1">
      <Position3D><X>9</X><Y>0.25</Y><Z>10.75</Z></Position3D>
      <Component Type="BoxPrimitive3D"><Property Name="Scale" Value="6,0.5,0.5" Type="Vector3"/><Property Name="Color" Value="82,78,70" Type="Color"/></Component>
    </Entity>
    <Entity Name="Step2">
      <Position3D><X>9</X><Y>0.375</Y><Z>11.25</Z></Position3D>
      <Component Type="BoxPrimitive3D"><Property Name="Scale" Value="6,0.75,0.5" Type="Vector3"/><Property Name="Color" Value="82,78,70" Type="Color"/></Component>
    </Entity>
    <Entity Name="Step3">
      <Position3D><X>9</X><Y>0.5</Y><Z>11.75</Z></Position3D>
      <Component Type="BoxPrimitive3D"><Property Name="Scale" Value="6,1.0,0.5" Type="Vector3"/><Property Name="Color" Value="82,78,70" Type="Color"/></Component>
    </Entity>
    <Entity Name="Step4">
      <Position3D><X>9</X><Y>0.625</Y><Z>12.25</Z></Position3D>
      <Component Type="BoxPrimitive3D"><Property Name="Scale" Value="6,1.25,0.5" Type="Vector3"/><Property Name="Color" Value="82,78,70" Type="Color"/></Component>
    </Entity>
    <Entity Name="Step5">
      <Position3D><X>9</X><Y>0.75</Y><Z>12.75</Z></Position3D>
      <Component Type="BoxPrimitive3D"><Property Name="Scale" Value="6,1.5,0.5" Type="Vector3"/><Property Name="Color" Value="82,78,70" Type="Color"/></Component>
    </Entity>
    <Entity Name="Step6">
      <Position3D><X>9</X><Y>0.875</Y><Z>13.25</Z></Position3D>
      <Component Type="BoxPrimitive3D"><Property Name="Scale" Value="6,1.75,0.5" Type="Vector3"/><Property Name="Color" Value="82,78,70" Type="Color"/></Component>
    </Entity>
    <Entity Name="Step7">
      <Position3D><X>9</X><Y>1.0</Y><Z>13.75</Z></Position3D>
      <Component Type="BoxPrimitive3D"><Property Name="Scale" Value="6,2.0,0.5" Type="Vector3"/><Property Name="Color" Value="82,78,70" Type="Color"/></Component>
    </Entity>

    <!-- A few perimeter walls (visual only; navmesh boundary edges do the blocking). -->
    <Entity Name="CorridorWestWall">
      <Position3D><X>-0.15</X><Y>1.5</Y><Z>15</Z></Position3D>
      <Component Type="BoxPrimitive3D"><Property Name="Scale" Value="0.3,3,10" Type="Vector3"/><Property Name="Color" Value="60,58,54" Type="Color"/></Component>
    </Entity>
    <Entity Name="PlatformBackWall">
      <Position3D><X>8</X><Y>3</Y><Z>20.15</Z></Position3D>
      <Component Type="BoxPrimitive3D"><Property Name="Scale" Value="8,2,0.3" Type="Vector3"/><Property Name="Color" Value="60,58,54" Type="Color"/></Component>
    </Entity>
    <Entity Name="CourtyardSouthWall">
      <Position3D><X>6</X><Y>1.5</Y><Z>-0.15</Z></Position3D>
      <Component Type="BoxPrimitive3D"><Property Name="Scale" Value="12,3,0.3" Type="Vector3"/><Property Name="Color" Value="60,58,54" Type="Color"/></Component>
    </Entity>

    <!-- ============================================================= -->
    <!-- Interactables. MUST be Mesh3D to appear in the ID buffer.     -->
    <!-- Scale is a guess for meter-scale; tune to taste.              -->
    <!-- ============================================================= -->

    <Entity Name="Tablet">
      <Position3D><X>4</X><Y>1.0</Y><Z>4</Z></Position3D>
      <Component Type="Mesh3D">
        <Property Name="ModelPath" Value="models/skull" Type="String"/>
        <Property Name="Scale" Value="0.0008,0.0008,0.0008" Type="Vector3"/>
        <Property Name="DiffuseColor" Value="0.8,0.75,0.6" Type="Vector3"/>
      </Component>
      <Component Type="Interactable3D">
        <Property Name="PromptText" Value="read the tablet" Type="String"/>
        <Property Name="Action" Value="show-word" Type="String"/>
        <Property Name="Message" Value="The glyphs speak of a buried road." Type="String"/>
      </Component>
    </Entity>

    <Entity Name="Totem">
      <Position3D><X>5</X><Y>1.0</Y><Z>17</Z></Position3D>
      <Component Type="Mesh3D">
        <Property Name="ModelPath" Value="models/skull" Type="String"/>
        <Property Name="Scale" Value="0.0008,0.0008,0.0008" Type="Vector3"/>
        <Property Name="DiffuseColor" Value="0.6,0.7,0.85" Type="Vector3"/>
      </Component>
      <Component Type="Interactable3D">
        <Property Name="PromptText" Value="touch the totem" Type="String"/>
        <Property Name="Action" Value="show-word" Type="String"/>
        <Property Name="Message" Value="A cold pillar hums beneath the platform." Type="String"/>
      </Component>
    </Entity>

    <!-- ============================================================= -->
    <!-- Lights (meter-scale ranges) and spawn point.                  -->
    <!-- ============================================================= -->

    <Entity Name="CourtyardLight">
      <Position3D><X>6</X><Y>5</Y><Z>4</Z></Position3D>
      <Component Type="PointLight">
        <Property Name="Range" Value="26" Type="Single"/>
        <Property Name="Intensity" Value="3.0" Type="Single"/>
      </Component>
    </Entity>
    <Entity Name="PlatformLight">
      <Position3D><X>8</X><Y>5</Y><Z>17</Z></Position3D>
      <Component Type="PointLight">
        <Property Name="Range" Value="24" Type="Single"/>
        <Property Name="Intensity" Value="2.5" Type="Single"/>
      </Component>
    </Entity>
    <Entity Name="TunnelLight">
      <Position3D><X>4</X><Y>2.5</Y><Z>17</Z></Position3D>
      <Component Type="PointLight">
        <Property Name="Range" Value="14" Type="Single"/>
        <Property Name="Intensity" Value="2.2" Type="Single"/>
      </Component>
    </Entity>

    <Entity Name="PlayerStart">
      <Position3D><X>3</X><Y>0</Y><Z>3</Z></Position3D>
    </Entity>

  </Entities>
</Scene>
