<Scene>
  <Entities>
    <Entity Name="level">
      <Position><X>0</X><Y>0</Y></Position>
      <Component Type="PowergridLevelComponent">
        <Property Name="HoldingSlots" Value="3" Type="int" />
        <Data>inventory:1,1</Data>
      </Component>
    </Entity>

    <!-- AND gate + goal: needs TU and BU to arrive on the same tick. -->
    <Entity Name="S">
      <Position><X>0</X><Y>0</Y></Position>
      <Component Type="PowerNodeComponent">
        <Property Name="NodeKind" Value="And" Type="enum" />
        <Data>goal</Data>
      </Component>
    </Entity>
    <Entity Name="goal">
      <Position><X>2</X><Y>0</Y></Position>
      <Component Type="PowerNodeComponent">
        <Property Name="IsGoal" Value="true" Type="bool" />
      </Component>
    </Entity>

    <!-- Inputs to S -->
    <Entity Name="TU">
      <Position><X>0</X><Y>2</Y></Position>
      <Component Type="PowerNodeComponent"><Data>S</Data></Component>
    </Entity>
    <Entity Name="BU">
      <Position><X>0</X><Y>-2</Y></Position>
      <Component Type="PowerNodeComponent"><Data>S</Data></Component>
    </Entity>

    <!-- Top: anchor TA -> Tmid -> TU (so S receives the top pulse at t3), and TA -> K lights the key at t1. -->
    <Entity Name="TA">
      <Position><X>-4</X><Y>2</Y></Position>
      <Component Type="PowerNodeComponent">
        <Property Name="IsAnchor" Value="true" Type="bool" />
        <Data>Tmid,K</Data>
      </Component>
    </Entity>
    <Entity Name="Tmid">
      <Position><X>-2</X><Y>2</Y></Position>
      <Component Type="PowerNodeComponent"><Data>TU</Data></Component>
    </Entity>
    <Entity Name="K">
      <Position><X>-2</X><Y>0</Y></Position>
      <Component Type="PowerNodeComponent" />
    </Entity>

    <!-- Bottom CORRECT (long): BL -> Bmid -> BU, with Bmid->BU locked until K fires. Matches the top at t3. -->
    <Entity Name="BL">
      <Position><X>-4</X><Y>-2</Y></Position>
      <Component Type="PowerNodeComponent">
        <Property Name="IsAnchor" Value="true" Type="bool" />
        <Data>Bmid</Data>
      </Component>
    </Entity>
    <Entity Name="Bmid">
      <Position><X>-2</X><Y>-2</Y></Position>
      <Component Type="PowerNodeComponent"><Data>BU</Data></Component>
    </Entity>

    <!-- Bottom DECOY (short): BS -> BU directly. Arrives a tick too early, so the AND never lines up. -->
    <Entity Name="BS">
      <Position><X>-1</X><Y>-4</Y></Position>
      <Component Type="PowerNodeComponent">
        <Property Name="IsAnchor" Value="true" Type="bool" />
        <Data>BU</Data>
      </Component>
    </Entity>

    <Entity Name="lock1">
      <Position><X>-1</X><Y>-2</Y></Position>
      <Component Type="EdgeLockComponent">
        <Property Name="PointA" Value="-1,-2.7" Type="Vector2" />
        <Property Name="PointB" Value="-1,-1.3" Type="Vector2" />
        <Property Name="KeyNode" Value="K" Type="string" />
      </Component>
    </Entity>
  </Entities>
</Scene>
